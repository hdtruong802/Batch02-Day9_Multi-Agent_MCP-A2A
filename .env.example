# LLM provider: gemini | openrouter
LLM_PROVIDER=gemini

# Google Gemini API (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.3

# OpenRouter (optional fallback — set LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=your_key_here
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

REGISTRY_URL=http://localhost:10000
A2A_HTTP_TIMEOUT=1800

# Demo UI (start_demo.ps1) — agents POST live trace events here
DEMO_TRACE_URL=http://localhost:10200
DEMO_PORT=10200
